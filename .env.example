DJANGO_SECRET_KEY=replace-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=*
TIME_ZONE=Asia/Jakarta

MYSQL_DATABASE=ebook_drm
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306

CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1

SOURCE_STORAGE_ROOT=./storage/sources
PACKAGE_STORAGE_ROOT=./storage/packages
MAX_UPLOAD_SIZE_MB=200

# 32-byte key encoded in base64
DRM_MASTER_KEY_B64=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=

# Multiline PEM private key; keep escaped newlines if set in .env file
DRM_RSA_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\nREPLACE_ME\n-----END PRIVATE KEY-----"
